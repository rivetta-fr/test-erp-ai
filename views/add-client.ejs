<div class="content-header">
  <h1>➕ Nouveau Client</h1>
  <div class="subtitle">Ajouter un nouveau client à votre base de données</div>
</div>

<div class="content-nav">
  <a href="/clients">← Retour aux Clients</a>
</div>

<form action="/clients" method="POST" class="form-container">
  <div class="form-group">
    <label for="name">🏢 Nom de l'entreprise:</label>
    <input type="text" id="name" name="name" placeholder="Ex: Société ABC" required>
  </div>

  <div class="form-group">
    <label for="contact_person">👤 Personne de contact:</label>
    <input type="text" id="contact_person" name="contact_person" placeholder="Ex: Jean Dupont">
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="email">📧 Email:</label>
      <input type="email" id="email" name="email" placeholder="contact@societe-abc.com">
    </div>

    <div class="form-group">
      <label for="phone">📞 Téléphone:</label>
      <input type="tel" id="phone" name="phone" placeholder="01 23 45 67 89">
    </div>
  </div>

  <div class="form-group">
    <label for="address">📍 Adresse:</label>
    <textarea id="address" name="address" rows="3" placeholder="Adresse complète de l'entreprise"></textarea>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn-primary">💾 Créer le Client</button>
    <a href="/clients" class="btn-secondary">Annuler</a>
  </div>
</form>


<div class="content-header">
  <h1>✏️ Modifier Commande</h1>
  <div class="subtitle">Modifier les informations de la commande</div>
</div>

<div class="content-nav">
  <a href="/orders">← Retour aux Commandes</a> |
  <a href="/orders/<%= order.id %>">Voir la Commande</a>
</div>

<form action="/orders/<%= order.id %>?_method=PUT" method="POST" class="form-container" id="orderForm" novalidate>
  <div class="form-group">
    <label for="client_id">👥 Client:</label>
    <select id="client_id" name="client_id" required
            aria-describedby="client-error" aria-required="true">
      <option value="">-- Choisir un client --</option>
      <% clients.forEach(client => { %>
        <option value="<%= client.id %>" <%= order.client_id == client.id ? 'selected' : '' %>><%= client.name %></option>
      <% }); %>
    </select>
    <div id="client-error" class="error-message" role="alert" aria-live="polite"></div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="origin">📍 Origine:</label>
      <input type="text" id="origin" name="origin" placeholder="Ex: Paris" required
             value="<%= order.origin %>"
             aria-describedby="origin-error" aria-required="true" maxlength="100">
      <div id="origin-error" class="error-message" role="alert" aria-live="polite"></div>
    </div>

    <div class="form-group">
      <label for="destination">🎯 Destination:</label>
      <input type="text" id="destination" name="destination" placeholder="Ex: Lyon" required
             value="<%= order.destination %>"
             aria-describedby="destination-error" aria-required="true" maxlength="100">
      <div id="destination-error" class="error-message" role="alert" aria-live="polite"></div>
    </div>
  </div>

  <div class="form-group">
    <label for="truck_id">🚛 Camion:</label>
    <select id="truck_id" name="truck_id" required
            aria-describedby="truck-error" aria-required="true">
      <option value="">-- Choisir un camion --</option>
      <% trucks.forEach(truck => { %>
        <option value="<%= truck.id %>" <%= order.truck_id == truck.id ? 'selected' : '' %>>
          <%= truck.name %> (Capacité: <%= truck.capacity %>kg) -
          <span class="status-badge status-<%= truck.status %>">
            <% if (truck.status === 'available') { %>Disponible
            <% } else if (truck.status === 'scheduled') { %>Planifié
            <% } else if (truck.status === 'in_transit') { %>En transit
            <% } else if (truck.status === 'completed') { %>Terminé
            <% } %>
          </span>
        </option>
      <% }); %>
    </select>
    <div id="truck-error" class="error-message" role="alert" aria-live="polite"></div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="departure_time">🕐 Date/Heure de Départ:</label>
      <input type="datetime-local" id="departure_time" name="departure_time" required
             value="<%= order.departure_time ? new Date(order.departure_time).toISOString().slice(0, 16) : '' %>"
             aria-describedby="departure-error" aria-required="true">
      <div id="departure-error" class="error-message" role="alert" aria-live="polite"></div>
    </div>

    <div class="form-group">
      <label for="arrival_time">🕐 Date/Heure d'Arrivée:</label>
      <input type="datetime-local" id="arrival_time" name="arrival_time" required
             value="<%= order.arrival_time ? new Date(order.arrival_time).toISOString().slice(0, 16) : '' %>"
             aria-describedby="arrival-error" aria-required="true">
      <div id="arrival-error" class="error-message" role="alert" aria-live="polite"></div>
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="cargo_description">📦 Description de la Cargaison:</label>
      <input type="text" id="cargo_description" name="cargo_description" placeholder="Ex: Électronique fragile"
             value="<%= order.cargo_description || '' %>"
             aria-describedby="cargo-error" maxlength="200">
      <div id="cargo-error" class="error-message" role="alert" aria-live="polite"></div>
    </div>

    <div class="form-group">
      <label for="weight">⚖️ Poids (kg):</label>
      <input type="number" id="weight" name="weight" placeholder="Ex: 1500" min="1" max="50000"
             value="<%= order.weight || '' %>"
             aria-describedby="weight-error">
      <div id="weight-error" class="error-message" role="alert" aria-live="polite"></div>
    </div>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn-primary" id="submitBtn">
      <span class="spinner-circular" id="submitSpinner" style="display: none; width: 16px; height: 16px; margin-right: 8px;"></span>
      💾 Mettre à Jour
    </button>
    <a href="/orders/<%= order.id %>" class="btn-secondary">Annuler</a>
  </div>
</form>

<style>
  .form-container {
    background-color: white;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    max-width: 700px;
    margin: 20px auto;
  }

  .form-row {
    display: flex;
    gap: 20px;
  }

  .form-row .form-group {
    flex: 1;
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: #333;
    font-size: 1rem;
  }

  .form-group input,
  .form-group select {
    width: 100%;
    padding: 12px;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }

  .form-group input:focus,
  .form-group select:focus {
    outline: none;
    border-color: #1976d2;
    box-shadow: 0 0 0 3px rgba(25, 118, 210, 0.1);
  }

  .form-group select {
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6,9 12,15 18,9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 12px center;
    background-size: 16px;
    padding-right: 40px;
  }

  .form-actions {
    display: flex;
    gap: 12px;
    margin-top: 30px;
  }

  .btn-primary {
    background-color: #1976d2;
    color: white;
    padding: 12px 24px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 600;
    transition: all 0.3s ease;
    flex: 1;
  }

  .btn-primary:hover {
    background-color: #1565c0;
    transform: translateY(-1px);
  }

  .btn-secondary {
    background-color: #f5f5f5;
    color: #666;
    padding: 12px 24px;
    border: 1px solid #ddd;
    border-radius: 8px;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    text-align: center;
    transition: all 0.3s ease;
    flex: 1;
  }

  .btn-secondary:hover {
    background-color: #e0e0e0;
    color: #333;
  }

  .status-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 12px;
    font-weight: bold;
    font-size: 0.8rem;
  }

  .status-available { background-color: #e8f5e9; color: #2e7d32; }
  .status-scheduled { background-color: #e1f5fe; color: #0277bd; }
  .status-in_transit { background-color: #fff3e0; color: #e65100; }
  .status-completed { background-color: #e8f5e9; color: #2e7d32; }

  /* Styles pour la validation et accessibilité */
  .form-group select.error,
  .form-group input.error {
    border-color: #d32f2f;
    box-shadow: 0 0 0 3px rgba(211, 47, 47, 0.1);
  }

  .error-message {
    color: #d32f2f;
    font-size: 0.875rem;
    margin-top: 4px;
    min-height: 1.2em;
    font-weight: 500;
  }

  .btn-primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .btn-primary:disabled:hover {
    transform: none;
    box-shadow: none;
  }

  @media (max-width: 768px) {
    .form-row {
      flex-direction: column;
    }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('orderForm');
  const submitBtn = document.getElementById('submitBtn');
  const submitSpinner = document.getElementById('submitSpinner');

  // Fonctions de validation
  function validateField(field, rules) {
    const value = field.value.trim();
    const errorElement = document.getElementById(field.id + '-error');
    let isValid = true;
    let errorMessage = '';

    // Validation requise
    if (field.hasAttribute('required') && !value) {
      isValid = false;
      errorMessage = 'Ce champ est obligatoire.';
    }
    // Validation date/heure
    else if (field.type === 'datetime-local' && value) {
      const selectedDate = new Date(value);
      const now = new Date();

      if (selectedDate < now) {
        isValid = false;
        errorMessage = 'La date doit être dans le futur.';
      }

      // Validation cohérence départ/arrivée
      if (field.id === 'arrival_time') {
        const departureField = document.getElementById('departure_time');
        const departureValue = departureField.value;

        if (departureValue && selectedDate <= new Date(departureValue)) {
          isValid = false;
          errorMessage = 'L\'heure d\'arrivée doit être après le départ.';
        }
      }
    }
    // Validation nombre positif
    else if (field.type === 'number' && value) {
      const numValue = parseFloat(value);
      if (isNaN(numValue) || numValue <= 0) {
        isValid = false;
        errorMessage = 'Veuillez saisir un nombre positif.';
      } else if (field.hasAttribute('max') && numValue > parseInt(field.getAttribute('max'))) {
        isValid = false;
        errorMessage = `Maximum ${field.getAttribute('max')} kg.`;
      }
    }
    // Validation longueur maximale
    else if (field.hasAttribute('maxlength') && value.length > parseInt(field.getAttribute('maxlength'))) {
      isValid = false;
      errorMessage = `Maximum ${field.getAttribute('maxlength')} caractères.`;
    }

    // Afficher/cacher l'erreur
    if (!isValid) {
      field.classList.add('error');
      errorElement.textContent = errorMessage;
      errorElement.style.display = 'block';
    } else {
      field.classList.remove('error');
      errorElement.textContent = '';
      errorElement.style.display = 'none';
    }

    return isValid;
  }

  // Validation en temps réel
  const fields = ['client_id', 'origin', 'destination', 'truck_id', 'departure_time', 'arrival_time', 'cargo_description', 'weight'];
  fields.forEach(fieldId => {
    const field = document.getElementById(fieldId);
    if (field) {
      field.addEventListener('blur', function() {
        validateField(this);
      });

      field.addEventListener('change', function() {
        if (this.classList.contains('error')) {
          validateField(this);
        }
        // Revalider l'arrivée quand le départ change
        if (this.id === 'departure_time') {
          const arrivalField = document.getElementById('arrival_time');
          if (arrivalField.classList.contains('error')) {
            validateField(arrivalField);
          }
        }
      });

      field.addEventListener('input', function() {
        if (this.classList.contains('error')) {
          validateField(this);
        }
      });
    }
  });

  // Validation lors de la soumission
  form.addEventListener('submit', function(e) {
    let isFormValid = true;

    // Valider tous les champs
    fields.forEach(fieldId => {
      const field = document.getElementById(fieldId);
      if (field && !validateField(field)) {
        isFormValid = false;
      }
    });

    if (!isFormValid) {
      e.preventDefault();
      // Focus sur le premier champ en erreur
      const firstError = form.querySelector('.error');
      if (firstError) {
        firstError.focus();
      }
      return false;
    }

    // Afficher le spinner et désactiver le bouton
    submitSpinner.style.display = 'inline-block';
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner-circular" style="width: 16px; height: 16px; margin-right: 8px;"></span>Mise à jour en cours...';

    // Le formulaire sera soumis normalement
  });

  // Navigation au clavier améliorée
  form.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && e.target.tagName !== 'TEXTAREA') {
      e.preventDefault();
      const formElements = Array.from(form.elements);
      const currentIndex = formElements.indexOf(e.target);
      const nextElement = formElements[currentIndex + 1];

      if (nextElement) {
        nextElement.focus();
      } else {
        submitBtn.focus();
      }
    }
  });
});
</script>
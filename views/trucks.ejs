<div class="content-header">
  <h1>🚛 Gestion des Camions</h1>
  <div class="subtitle">Gérer votre flotte de véhicules</div>
</div>

<div class="content-nav">
  <a href="/trucks/add">➕ Ajouter un Camion</a>
</div>

<% if (trucks && trucks.length > 0) { %>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Nom</th>
        <th>Capacité</th>
        <th>Statut</th>
      </tr>
    </thead>
    <tbody>
      <% trucks.forEach(truck => { %>
        <tr>
          <td><%= truck.id %></td>
          <td><a href="/trucks/<%= truck.id %>" style="color: #1976d2; text-decoration: none; font-weight: 500;"><%= truck.name %></a></td>
          <td><%= truck.capacity %> kg</td>
          <td>
            <span class="status-badge status-<%= truck.status %>">
              <% if (truck.status === 'available') { %>
                ✓ Disponible
              <% } else if (truck.status === 'in_transit') { %>
                🚚 En transit
              <% } else if (truck.status === 'scheduled') { %>
                📅 Planifié
              <% } else if (truck.status === 'completed') { %>
                ✓ Complété
              <% } else { %>
                <%= truck.status %>
              <% } %>
            </span>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } else { %>
  <div style="text-align: center; padding: 40px; color: #666;">
    <p>🚛 Aucun camion enregistré</p>
    <p><a href="/trucks/add" style="color: #1976d2; text-decoration: none;">Ajouter votre premier camion</a></p>
  </div>
<% } %>
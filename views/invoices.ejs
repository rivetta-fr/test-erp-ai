<div class="content-header">
  <h1>💰 Gestion des Factures</h1>
  <div class="subtitle">Suivre et gérer les factures de transport</div>
</div>

<div class="content-nav">
  <a href="/invoices/add">➕ Nouvelle Facture</a>
</div>

<% if (invoices && invoices.length > 0) { %>
  <div class="table-container">
    <table class="data-table">
      <thead>
        <tr>
          <th>N° Facture</th>
          <th>Client</th>
          <th>Montant HT</th>
          <th>TVA (20%)</th>
          <th>Montant TTC</th>
          <th>Statut</th>
          <th>Date d'émission</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% invoices.forEach(invoice => { %>
          <tr>
            <td><strong><%= invoice.invoice_number %></strong></td>
            <td><%= invoice.client_name %></td>
            <td><%= invoice.amount_ht %> €</td>
            <td><%= invoice.tva_amount %> €</td>
            <td><strong><%= invoice.amount_ttc %> €</strong></td>
            <td>
              <span class="status-badge status-<%= invoice.status %>">
                <% if (invoice.status === 'pending') { %>⏳ En attente
                <% } else if (invoice.status === 'paid') { %>💰 Payée
                <% } else if (invoice.status === 'overdue') { %>⚠️ En retard
                <% } %>
              </span>
            </td>
            <td><%= new Date(invoice.issued_at).toLocaleDateString('fr-FR') %></td>
            <td>
              <% if (invoice.status === 'pending') { %>
                <form action="/invoices/<%= invoice.id %>/pay" method="POST" class="inline-form">
                  <button type="submit" class="btn-update">💰 Payer</button>
                </form>
              <% } else { %>
                <span style="color: #666; font-size: 0.8rem;">✓ Traité</span>
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } else { %>
  <div style="text-align: center; padding: 40px; color: #666;">
    <p>💰 Aucune facture enregistrée</p>
    <p><a href="/invoices/add" style="color: #1976d2; text-decoration: none;">Créer votre première facture</a></p>
  </div>
<% } %>

<style>
  .table-container {
    width: 100%;
    overflow-x: auto;
    margin: 20px 0;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  .data-table {
    width: 100%;
    min-width: 800px;
    border-collapse: collapse;
    background-color: white;
    border-radius: 8px;
    overflow: hidden;
  }

  .data-table th {
    background-color: #f5f5f5;
    padding: 12px 8px;
    text-align: left;
    font-weight: 600;
    color: #333;
    border-bottom: 2px solid #e0e0e0;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .data-table td {
    padding: 12px 8px;
    border-bottom: 1px solid #e0e0e0;
    font-size: 0.9rem;
  }

  .data-table tr:hover {
    background-color: #f9f9f9;
  }

  .btn-update {
    background-color: #66bb6a;
    color: white;
    padding: 4px 8px;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 500;
    margin: 0;
    transition: all 0.2s ease;
    white-space: nowrap;
    min-width: auto;
    height: 24px;
    line-height: 1;
  }

  .btn-update:hover {
    background-color: #4caf50;
    transform: translateY(-1px);
  }

  .status-badge {
    display: inline-block;
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .data-table th:last-child,
  .data-table td:last-child {
    width: 80px;
    min-width: 80px;
    max-width: 100px;
    text-align: center;
    padding: 8px 4px !important;
  }

  .inline-form {
    display: inline;
    margin: 0;
    padding: 0;
    border: none;
  }

  /* Responsive adjustments */
  @media (max-width: 1200px) {
    .table-container {
      margin: 20px -10px;
    }
  }
</style>
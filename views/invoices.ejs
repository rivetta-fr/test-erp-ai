<div class="content-header">
  <h1>💰 Gestion des Factures</h1>
  <div class="subtitle">Suivre et gérer les factures de transport</div>
</div>

<div class="content-nav">
  <a href="/invoices/add">➕ Nouvelle Facture</a>
</div>

<% if (invoices && invoices.length > 0) { %>
  <table class="data-table">
    <thead>
      <tr>
        <th>N° Facture</th>
        <th>Client</th>
        <th>Montant HT</th>
        <th>TVA (20%)</th>
        <th>Montant TTC</th>
        <th>Statut</th>
        <th>Date d'émission</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% invoices.forEach(invoice => { %>
        <tr>
          <td><strong><%= invoice.invoice_number %></strong></td>
          <td><%= invoice.client_name %></td>
          <td><%= invoice.amount_ht %> €</td>
          <td><%= invoice.tva_amount %> €</td>
          <td><strong><%= invoice.amount_ttc %> €</strong></td>
          <td>
            <span class="status-badge status-<%= invoice.status %>">
              <% if (invoice.status === 'pending') { %>⏳ En attente
              <% } else if (invoice.status === 'paid') { %>💰 Payée
              <% } else if (invoice.status === 'overdue') { %>⚠️ En retard
              <% } %>
            </span>
          </td>
          <td><%= new Date(invoice.issued_at).toLocaleDateString('fr-FR') %></td>
          <td>
            <% if (invoice.status === 'pending') { %>
              <form action="/invoices/<%= invoice.id %>/pay" method="POST" style="display:inline;">
                <button type="submit" class="btn-update" style="background-color: #4caf50;">💰 Marquer comme payée</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } else { %>
  <div style="text-align: center; padding: 40px; color: #666;">
    <p>💰 Aucune facture enregistrée</p>
    <p><a href="/invoices/add" style="color: #1976d2; text-decoration: none;">Créer votre première facture</a></p>
  </div>
<% } %>

<style>
  .data-table {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
    background-color: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  .data-table th {
    background-color: #f5f5f5;
    padding: 15px;
    text-align: left;
    font-weight: 600;
    color: #333;
    border-bottom: 2px solid #e0e0e0;
  }

  .data-table td {
    padding: 15px;
    border-bottom: 1px solid #e0e0e0;
  }

  .data-table tr:hover {
    background-color: #f9f9f9;
  }

  .btn-update {
    background-color: #66bb6a;
    color: white;
    padding: 8px 16px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
    margin-right: 8px;
    transition: all 0.3s ease;
  }

  .btn-update:hover {
    background-color: #4caf50;
    transform: translateY(-1px);
  }

  .status-pending { background-color: #fff9c4; color: #f57f17; }
  .status-paid { background-color: #e8f5e9; color: #2e7d32; }
  .status-overdue { background-color: #ffebee; color: #c62828; }
</style>